# Backend Environment Variables - EXAMPLE
# Copy this to .env and update values for your environment

# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# For development (SQLite):
DATABASE_URL=sqlite:///db.sqlite3

# For production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/breathe_esg

# Note: In production, set DEBUG=False and provide DATABASE_URL.
# Render should use DATABASE_URL from your PostgreSQL service.

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# For production:
# CORS_ALLOWED_ORIGINS=https://your-frontend-url.onrender.com

# Email Backend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Celery Configuration (optional)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
